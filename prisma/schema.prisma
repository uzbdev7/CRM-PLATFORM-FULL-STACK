generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  STUDENT
  TEACHER
  MANAGEMENT
  ADMINISTRATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  FREEZE
}

enum Status {
  ACTIVE
  INACTIVE
  FREEZE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WeekDays {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum HomeworkStatus {
  PENDING
  APPROVED
  REJECTED
  MISSED
  DELAY
}

model User {
  id         Int        @id @default(autoincrement())
  fullName   String
  photo      String?
  password   String
  position   String?
  hire_date  DateTime
  email      String     @unique
  role       Role       @default(STUDENT)
  address    String?
  status     UserStatus @default(ACTIVE)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  groups          Group[]
  lessons         Lesson[]
  attendances     Attendance[]
  homework        Homework[]
  lessonVideos    LessonVideo[]
  homeworkResults HomeworkResult[]
}

model Teacher {
  id         Int        @id @default(autoincrement())
  fullName   String
  photo      String?
  password   String
  email      String     @unique
  experience Int
  position   String
  status     UserStatus @default(ACTIVE)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  groups          Group[]
  lessons         Lesson[]
  attendances     Attendance[]
  homework        Homework[]
  lessonVideos    LessonVideo[]
  homeworkResults HomeworkResult[]
  ratings         Rating[]
}

model Student {
  id         Int        @id @default(autoincrement())
  fullName   String
  photo      String?
  password   String
  birt_date  DateTime
  email      String     @unique
  status     UserStatus @default(ACTIVE)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  studentGroups     StudentGroup[]
  attendances       Attendance[]
  homeworkResponses HomeworkResponse[]
  homeworkResults   HomeworkResult[]
  ratings           Rating[]
}

model Course {
  id             Int          @id @default(autoincrement())
  name           String       @unique
  durationMonth  Int
  durationLesson Int
  status         Status
  level          CourseLevel?
  price          Decimal
  description    String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  groups Group[]
}

model Room {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  capacity   Int
  status     Status   @default(ACTIVE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  groups     Group[]
}

model Group {
  id         Int        @id @default(autoincrement())
  teacherId  Int
  userId     Int
  roomId     Int
  courseId   Int
  name       String     @unique
  startDate  DateTime
  startTime  String
  weeKDays   WeekDays[]
  status     Status     @default(ACTIVE)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  studentGroups StudentGroup[]

  user    User     @relation(fields: [userId], references: [id])
  teacher Teacher  @relation(fields: [teacherId], references: [id])
  room    Room     @relation(fields: [roomId], references: [id])
  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]

  @@unique([courseId, name])
}

model StudentGroup {
  id         Int      @id @default(autoincrement())
  groupId    Int
  studentId  Int
  status     Status   @default(ACTIVE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  group   Group   @relation(fields: [groupId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([groupId, studentId])
}

model Lesson {
  id         Int      @id @default(autoincrement())
  title      String
  groupId    Int
  userId     Int?
  teacherId  Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  group        Group         @relation(fields: [groupId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  teacher      Teacher?      @relation(fields: [teacherId], references: [id])
  attendances  Attendance[]
  homework     Homework[]
  lessonVideos LessonVideo[]
  ratings      Rating[]
}

model Attendance {
  id         Int      @id @default(autoincrement())
  lessonId   Int
  userId     Int?
  teacherId  Int?
  studentId  Int
  isPresent  Boolean
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])
  student Student  @relation(fields: [studentId], references: [id])
  lesson  Lesson   @relation(fields: [lessonId], references: [id])
}

model Homework {
  id         Int      @id @default(autoincrement())
  lessonId   Int
  userId     Int?
  teacherId  Int?
  title      String
  file       String?
  durationTime Int      @default(16)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id])
  teacher           Teacher?           @relation(fields: [teacherId], references: [id])
  lesson            Lesson             @relation(fields: [lessonId], references: [id])
  homeworkResponses HomeworkResponse[]
  homeworkResults   HomeworkResult[]
}

model LessonVideo {
  id           Int      @id @default(autoincrement())
  lessonId     Int
  userId       Int?
  teacherId    Int?
  file         String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])
  lesson  Lesson   @relation(fields: [lessonId], references: [id])
}

model HomeworkResponse {
  id         Int            @id @default(autoincrement())
  homeworkId Int
  studentId  Int
  title      String
  file       String?
  status     HomeworkStatus @default(PENDING)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  student  Student  @relation(fields: [studentId], references: [id])
  homework Homework @relation(fields: [homeworkId], references: [id])
}

model HomeworkResult {
  id         Int            @id @default(autoincrement())
  homeworkId Int
  studentId  Int
  userId     Int?
  teacherId  Int?
  title      String
  file       String?
  score      Int
  status     HomeworkStatus
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  user     User?    @relation(fields: [userId], references: [id])
  teacher  Teacher? @relation(fields: [teacherId], references: [id])
  student  Student  @relation(fields: [studentId], references: [id])
  homework Homework @relation(fields: [homeworkId], references: [id])
}

model Rating {
  id         Int      @id @default(autoincrement())
  lessonId   Int
  teacherId  Int
  studentId  Int
  score      Int
  created_at DateTime @default(now())

  lesson  Lesson   @relation(fields: [lessonId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}
